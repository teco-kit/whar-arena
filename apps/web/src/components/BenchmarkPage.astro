---
type MetaIcon = "calendar" | "runs" | "models" | "datasets";
type MetaItem = {
  icon: MetaIcon;
  label: string;
  value: string | number;
  datetime?: string;
};

interface Props {
  title: string;
  description: string;
  headingId?: string;
  metaItems?: MetaItem[];
}

const {
  title,
  description,
  headingId = `${String(title).toLowerCase().replace(/[^a-z0-9]+/g, "-")}-heading`,
  metaItems = [],
} = Astro.props;

function formatValue(value: string | number) {
  return typeof value === "number" ? value.toLocaleString("en-US") : value;
}
---

<main class="page-shell">
  <section class="page-intro" aria-labelledby={headingId}>
    <h1 id={headingId}>{title}</h1>
    <p>{description}</p>
  </section>
  {
    metaItems.length > 0 && (
      <section class="page-meta" aria-label={`${title} summary`}>
        <dl class="benchmark-meta">
          {metaItems.map((item) => (
            <div>
              <span class="meta-icon" aria-hidden="true">
                {item.icon === "calendar" && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 3v3M17 3v3M4.5 9h15M6.5 5h11a2 2 0 0 1 2 2v10.5a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
                  </svg>
                )}
                {item.icon === "runs" && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 7a3 3 0 1 1 3 3H7V7ZM14 14h3a3 3 0 1 1-3 3v-3ZM10 10l4 4M14 10l-4 4" />
                  </svg>
                )}
                {item.icon === "models" && (
                  <svg viewBox="0 0 24 24">
                    <path d="M9 8h6v6H9zM9 3v3M15 3v3M9 16v3M15 16v3M3 9h3M3 13h3M18 9h3M18 13h3M11 10h2v2h-2z" />
                  </svg>
                )}
                {item.icon === "datasets" && (
                  <svg viewBox="0 0 24 24">
                    <path d="M5 6c0-1.7 3.1-3 7-3s7 1.3 7 3-3.1 3-7 3-7-1.3-7-3ZM5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />
                  </svg>
                )}
              </span>
              <dt>{item.label}</dt>
              <dd>
                {item.datetime ? (
                  <time datetime={item.datetime}>{formatValue(item.value)}</time>
                ) : (
                  formatValue(item.value)
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>
    )
  }
  <slot />
</main>

<style>
  .page-shell {
    width: min(1440px, calc(100vw - 24px));
    margin: 0 auto;
    padding: 12px 0 40px;
  }

  .page-intro,
  .page-meta {
    display: grid;
    gap: 15px;
  }

  .page-intro {
    padding: 0;
  }

  .page-intro h1 {
    margin: 0;
    font-family: var(--display-serif);
    font-size: 1.55rem;
    font-weight: 500;
    line-height: 1.05;
  }

  .page-intro p {
    margin: 0;
    color: var(--muted-strong);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .page-meta {
    padding: 6px 0 14px;
  }

  .benchmark-meta {
    display: flex;
    flex-wrap: nowrap;
    gap: 22px;
    margin: 0;
    overflow-x: auto;
    white-space: nowrap;
  }

  .benchmark-meta div {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    gap: 6px;
  }

  .meta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 17px;
    height: 17px;
    color: var(--ink);
  }

  .meta-icon svg {
    display: block;
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .benchmark-meta dt {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .benchmark-meta dd {
    margin: 0;
    color: var(--ink);
    font-family: "DM Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
    font-weight: 500;
  }
</style>
