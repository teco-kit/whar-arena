---
import BenchmarkPage from "./BenchmarkPage.astro";
import Leaderboard from "./Leaderboard.svelte";
import catalog from "../generated/catalog.json";
import deploymentTradeoffs from "../generated/deployment-tradeoffs.json";
import paperBenchmark from "../generated/paper-benchmark.json";
import results from "../generated/results.json";

const usePaperStaticBenchmark = true;
const liveBenchmark = { catalog, results };
const benchmark = usePaperStaticBenchmark ? paperBenchmark : liveBenchmark;
const leaderboardDate = "May 1, 2026";
const leaderboardDateTime = "2026-05-01";
const trainingRuns = 4760;
const modelCount = benchmark.catalog.models.length;
const datasetCount = benchmark.catalog.datasets.length;
---

<BenchmarkPage
  title="Leaderboard"
  headingId="leaderboard-heading"
  description="WHAR Arena benchmarks wearable human activity recognition models across standardized datasets, ranking predictive performance together with deployment-oriented efficiency."
  metaItems={[
    { icon: "calendar", label: "Snapshot", value: leaderboardDate, datetime: leaderboardDateTime },
    { icon: "runs", label: "Training Runs", value: trainingRuns },
    { icon: "models", label: "Models", value: modelCount },
    { icon: "datasets", label: "Datasets", value: datasetCount },
  ]}
>
  <Leaderboard
    client:load
    catalog={benchmark.catalog}
    deploymentTradeoffs={deploymentTradeoffs}
    results={benchmark.results}
  />
</BenchmarkPage>
