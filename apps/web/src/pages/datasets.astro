---
import BaseLayout from "../layouts/BaseLayout.astro";
import datasetDetailsData from "../generated/dataset-details.json";
import datasetPaperDetailsData from "../generated/dataset-paper-details.json";
import paperBenchmark from "../generated/paper-benchmark.json";
import paperLinks from "../generated/paper-links.json";

type Dataset = {
  id: string;
  name: string;
};

type DatasetDetail = {
  year: number;
  citations: number;
  subjects: number;
  activities: number;
  settings: string;
  deviceTypes: string;
  sensorModalities: string;
  channels: number;
};

type PaperLink = {
  title: string;
  url: string;
};

type DatasetPaperDetail = {
  institutions?: string[];
  authors?: Array<{
    name: string;
    affiliation: string;
  }>;
};

type LabelPart = {
  id: string;
  name: string;
};

const datasetDetails = datasetDetailsData as {
  source: {
    table: string;
    note: string;
    abbreviations: string;
  };
  datasets: Record<string, DatasetDetail>;
};
const datasetPaperDetails = datasetPaperDetailsData as {
  source: {
    note: string;
  };
  datasets: Record<string, DatasetPaperDetail>;
};
const benchmark = paperBenchmark as { catalog: { datasets: Dataset[] } };
const links = paperLinks as { datasets: Record<string, PaperLink> };
const datasetNames = new Map(benchmark.catalog.datasets.map((dataset) => [dataset.id, dataset.name]));
const settingLabels: Record<string, string> = {
  ADL: "Activities of Daily Living",
  Fall: "Fall Detection",
  Fit: "Fitness",
  Health: "Health",
  Loc: "Locomotion",
  Sports: "Sports",
};
const deviceTypeLabels: Record<string, string> = {
  ActivityTracker: "Activity Tracker",
  Belt: "Belt",
  Glasses: "Smart Glasses",
  Helmet: "Helmet",
  LifeMonitor: "Life Monitor",
  Mask: "Mask",
  Node: "Sensor Node",
  Phone: "Phone",
  Watch: "Watch",
};
const sensorModalityLabels: Record<string, string> = {
  Acc: "Accelerometer",
  ALS: "ALS",
  Baro: "Barometer",
  ECG: "ECG",
  EEG: "EEG",
  EMG: "EMG",
  Flow: "Flow Sensor",
  Gas: "Gas Sensor",
  GPS: "GPS",
  Gyr: "Gyroscope",
  HR: "HR",
  Mag: "Magnetometer",
  Resp: "Respiration Sensor",
  Stretch: "Stretch Sensor",
};
const datasets = Object.entries(datasetDetails.datasets)
  .map(([id, detail]) => {
    const paperDetail = datasetPaperDetails.datasets[id] ?? { institutions: [], authors: [] };
    const settingParts = labelParts(detail.settings, formatSetting);
    const deviceTypeParts = labelParts(detail.deviceTypes, formatDeviceType);
    const sensorModalityParts = labelParts(detail.sensorModalities, formatSensorModality);

    return {
      id,
      name: datasetNames.get(id) ?? id,
      detail,
      settingParts,
      deviceTypeParts,
      sensorModalityParts,
      settingsLabel: labelText(settingParts),
      deviceTypesLabel: labelText(deviceTypeParts),
      sensorModalitiesLabel: labelText(sensorModalityParts),
      paperDetail,
      institutionSummary: formatInstitutionSummary(paperDetail.institutions ?? []),
      paperLink: links.datasets[id] ?? null,
    };
  })
  .sort((a, b) => b.detail.year - a.detail.year || a.name.localeCompare(b.name));
const settingOptions = uniqueParts(datasets.flatMap((dataset) => splitList(dataset.detail.settings)));
const sensorModalityOptions = uniqueParts(
  datasets.flatMap((dataset) => splitList(dataset.detail.sensorModalities)),
);
const deviceTypeOptions = uniqueParts(
  datasets.flatMap((dataset) => splitList(dataset.detail.deviceTypes)),
);
const subjectsMax = roundMetricMax(datasets.map((dataset) => dataset.detail.subjects));
const activitiesMax = roundMetricMax(datasets.map((dataset) => dataset.detail.activities));
const channelsMax = roundMetricMax(datasets.map((dataset) => dataset.detail.channels));
const snapshotDate = "May 1, 2026";
const snapshotDateTime = "2026-05-01";

function splitList(value: string) {
  return value
    .split(",")
    .map((part) => part.trim())
    .filter(Boolean);
}

function uniqueParts(parts: string[]) {
  return [...new Set(parts)].sort((a, b) => a.localeCompare(b));
}

function labelParts(value: string, formatter: (part: string) => string): LabelPart[] {
  return splitList(value).map((part) => ({ id: part, name: formatter(part) }));
}

function labelText(parts: LabelPart[]) {
  return parts.map((part) => part.name).join(", ");
}

function labelData(parts: LabelPart[]) {
  return parts.map((part) => part.name).join("|");
}

function formatSetting(part: string) {
  return settingLabels[part] ?? part;
}

function formatDeviceType(part: string) {
  return deviceTypeLabels[part] ?? part;
}

function formatSensorModality(part: string) {
  return sensorModalityLabels[part] ?? part;
}

function optionId(kind: string, value: string) {
  return `dataset-${kind}-filter-${value.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
}

function roundMetricMax(values: number[]) {
  const max = Math.max(...values);
  if (!Number.isFinite(max) || max <= 0) return 0;

  const step = 10 ** Math.max(0, Math.floor(Math.log10(max)) - 1);
  return Math.ceil(max / step) * step;
}

function formatRangeMetric(value: number) {
  return value.toLocaleString("en-US");
}

function formatInstitutionSummary(institutions: string[]) {
  if (institutions.length === 0) return "Institution pending";
  if (institutions.length > 3) return [...institutions.slice(0, 2), "et al."].join(", ");
  return institutions.join(", ");
}
---

<BaseLayout title="WHAR Arena | Datasets">
  <main class="page-shell">
    <section class="catalog-intro" aria-labelledby="datasets-heading">
      <h1 id="datasets-heading">Datasets</h1>
      <p>{datasetDetails.source.table} dataset catalog for the static WHAR Arena paper snapshot.</p>
    </section>
    <section class="catalog-meta" aria-label="Datasets summary">
      <dl class="benchmark-meta">
        <div>
          <span class="meta-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M7 3v3M17 3v3M4.5 9h15M6.5 5h11a2 2 0 0 1 2 2v10.5a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
            </svg>
          </span>
          <dt>Snapshot</dt>
          <dd><time datetime={snapshotDateTime}>{snapshotDate}</time></dd>
        </div>
        <div>
          <span class="meta-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M5 6c0-1.7 3.1-3 7-3s7 1.3 7 3-3.1 3-7 3-7-1.3-7-3ZM5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />
            </svg>
          </span>
          <dt>Datasets</dt>
          <dd>{datasets.length}</dd>
        </div>
      </dl>
    </section>

    <section class="arena-panel filter-panel">
      <div class="panel-header">
        <h2>Filters</h2>
      </div>

      <div class="filter-content">
        <div class="dataset-filter range-dataset-filter">
          <span class="filter-label">Subjects</span>
          <details>
            <summary aria-label="Subjects">
              <span data-range-summary="subjects">0 - {formatRangeMetric(subjectsMax)}</span>
              <span class="filter-count" data-range-count="subjects">range</span>
            </summary>
            <div class="filter-menu range-menu">
              <div class="range-fields">
                <label>
                  <span>Min</span>
                  <input
                    id="dataset-subjects-min"
                    type="number"
                    min="0"
                    max={subjectsMax}
                    step="1"
                    value="0"
                    inputmode="numeric"
                    data-range-kind="subjects"
                    data-range-bound="min"
                    data-range-default="0"
                  />
                </label>
                <label>
                  <span>Max</span>
                  <input
                    id="dataset-subjects-max"
                    type="number"
                    min="0"
                    max={subjectsMax}
                    step="1"
                    value={subjectsMax}
                    inputmode="numeric"
                    data-range-kind="subjects"
                    data-range-bound="max"
                    data-range-default={subjectsMax}
                  />
                </label>
              </div>
              <button type="button" class="range-reset" data-range-reset="subjects">Reset</button>
            </div>
          </details>
        </div>

        <div class="dataset-filter range-dataset-filter">
          <span class="filter-label">Activities</span>
          <details>
            <summary aria-label="Activities">
              <span data-range-summary="activities">0 - {formatRangeMetric(activitiesMax)}</span>
              <span class="filter-count" data-range-count="activities">range</span>
            </summary>
            <div class="filter-menu range-menu">
              <div class="range-fields">
                <label>
                  <span>Min</span>
                  <input
                    id="dataset-activities-min"
                    type="number"
                    min="0"
                    max={activitiesMax}
                    step="1"
                    value="0"
                    inputmode="numeric"
                    data-range-kind="activities"
                    data-range-bound="min"
                    data-range-default="0"
                  />
                </label>
                <label>
                  <span>Max</span>
                  <input
                    id="dataset-activities-max"
                    type="number"
                    min="0"
                    max={activitiesMax}
                    step="1"
                    value={activitiesMax}
                    inputmode="numeric"
                    data-range-kind="activities"
                    data-range-bound="max"
                    data-range-default={activitiesMax}
                  />
                </label>
              </div>
              <button type="button" class="range-reset" data-range-reset="activities">Reset</button>
            </div>
          </details>
        </div>

        <div class="dataset-filter range-dataset-filter">
          <span class="filter-label">Channels</span>
          <details>
            <summary aria-label="Channels">
              <span data-range-summary="channels">0 - {formatRangeMetric(channelsMax)}</span>
              <span class="filter-count" data-range-count="channels">range</span>
            </summary>
            <div class="filter-menu range-menu">
              <div class="range-fields">
                <label>
                  <span>Min</span>
                  <input
                    id="dataset-channels-min"
                    type="number"
                    min="0"
                    max={channelsMax}
                    step="1"
                    value="0"
                    inputmode="numeric"
                    data-range-kind="channels"
                    data-range-bound="min"
                    data-range-default="0"
                  />
                </label>
                <label>
                  <span>Max</span>
                  <input
                    id="dataset-channels-max"
                    type="number"
                    min="0"
                    max={channelsMax}
                    step="1"
                    value={channelsMax}
                    inputmode="numeric"
                    data-range-kind="channels"
                    data-range-bound="max"
                    data-range-default={channelsMax}
                  />
                </label>
              </div>
              <button type="button" class="range-reset" data-range-reset="channels">Reset</button>
            </div>
          </details>
        </div>

        <div class="dataset-filter">
          <span class="filter-label">Settings</span>
          <details>
            <summary aria-label="Settings">
              <span data-filter-summary="settings">All settings</span>
              <span class="filter-count" data-filter-count="settings">
                {settingOptions.length}/{settingOptions.length}
              </span>
            </summary>
            <div class="filter-menu">
              <div class="filter-actions" aria-label="Settings selection actions">
                <button type="button" data-filter-action="all" data-filter-target="settings">
                  All
                </button>
                <button type="button" data-filter-action="none" data-filter-target="settings">
                  None
                </button>
              </div>
              <div class="filter-options">
                {settingOptions.map((item) => (
                  <div class="filter-option" data-filter-option="settings">
                    <input
                      id={optionId("setting", item)}
                      type="checkbox"
                      value={item}
                      data-filter-kind="settings"
                      checked
                    />
                    <label
                      class="filter-check"
                      for={optionId("setting", item)}
                      aria-label={`Toggle ${formatSetting(item)}`}
                    ></label>
                    <label class="filter-name-toggle" for={optionId("setting", item)}>
                      <span class="pill">{formatSetting(item)}</span>
                    </label>
                  </div>
                ))}
              </div>
            </div>
          </details>
        </div>

        <div class="dataset-filter">
          <span class="filter-label">Device Types</span>
          <details>
            <summary aria-label="Device Types">
              <span data-filter-summary="deviceTypes">All device types</span>
              <span class="filter-count" data-filter-count="deviceTypes">
                {deviceTypeOptions.length}/{deviceTypeOptions.length}
              </span>
            </summary>
            <div class="filter-menu">
              <div class="filter-actions" aria-label="Device type selection actions">
                <button type="button" data-filter-action="all" data-filter-target="deviceTypes">
                  All
                </button>
                <button type="button" data-filter-action="none" data-filter-target="deviceTypes">
                  None
                </button>
              </div>
              <div class="filter-options">
                {deviceTypeOptions.map((item) => (
                  <div class="filter-option" data-filter-option="deviceTypes">
                    <input
                      id={optionId("device-type", item)}
                      type="checkbox"
                      value={item}
                      data-filter-kind="deviceTypes"
                      checked
                    />
                    <label
                      class="filter-check"
                      for={optionId("device-type", item)}
                      aria-label={`Toggle ${formatDeviceType(item)}`}
                    ></label>
                    <label class="filter-name-toggle" for={optionId("device-type", item)}>
                      <span class="pill">{formatDeviceType(item)}</span>
                    </label>
                  </div>
                ))}
              </div>
            </div>
          </details>
        </div>

        <div class="dataset-filter">
          <span class="filter-label">Sensor Modalities</span>
          <details>
            <summary aria-label="Sensor Modalities">
              <span data-filter-summary="sensorModalities">All sensor modalities</span>
              <span class="filter-count" data-filter-count="sensorModalities">
                {sensorModalityOptions.length}/{sensorModalityOptions.length}
              </span>
            </summary>
            <div class="filter-menu">
              <div class="filter-actions" aria-label="Sensor modality selection actions">
                <button type="button" data-filter-action="all" data-filter-target="sensorModalities">
                  All
                </button>
                <button type="button" data-filter-action="none" data-filter-target="sensorModalities">
                  None
                </button>
              </div>
              <div class="filter-options">
                {sensorModalityOptions.map((item) => (
                  <div class="filter-option" data-filter-option="sensorModalities">
                    <input
                      id={optionId("sensor-modality", item)}
                      type="checkbox"
                      value={item}
                      data-filter-kind="sensorModalities"
                      checked
                    />
                    <label
                      class="filter-check"
                      for={optionId("sensor-modality", item)}
                      aria-label={`Toggle ${formatSensorModality(item)}`}
                    ></label>
                    <label class="filter-name-toggle" for={optionId("sensor-modality", item)}>
                      <span class="pill">{formatSensorModality(item)}</span>
                    </label>
                  </div>
                ))}
              </div>
            </div>
          </details>
        </div>
      </div>
    </section>

    <section class="arena-panel">
      <div class="panel-header">
        <h2><span data-visible-dataset-count>{datasets.length}</span> Datasets</h2>
      </div>
      <div class="table-wrap">
        <table class="catalog-table">
          <thead>
            <tr>
              <th>Name</th>
              <th aria-sort="descending">
                <button
                  class="sort-button is-active"
                  type="button"
                  data-sort-key="year"
                  data-sort-type="number"
                  data-sort-default="desc"
                  data-sort-direction="desc"
                >
                  Year
                  <span class="sort-arrows" aria-hidden="true">
                    <span class="sort-arrow-up"></span>
                    <span class="sort-arrow-down"></span>
                  </span>
                </button>
              </th>
              <th aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="subjects"
                  data-sort-type="number"
                  data-sort-default="asc"
                >
                  Subjects
                  <span class="sort-arrows" aria-hidden="true">
                    <span class="sort-arrow-up"></span>
                    <span class="sort-arrow-down"></span>
                  </span>
                </button>
              </th>
              <th aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="activities"
                  data-sort-type="number"
                  data-sort-default="asc"
                >
                  Activities
                  <span class="sort-arrows" aria-hidden="true">
                    <span class="sort-arrow-up"></span>
                    <span class="sort-arrow-down"></span>
                  </span>
                </button>
              </th>
              <th aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="channels"
                  data-sort-type="number"
                  data-sort-default="asc"
                >
                  Channels
                  <span class="sort-arrows" aria-hidden="true">
                    <span class="sort-arrow-up"></span>
                    <span class="sort-arrow-down"></span>
                  </span>
                </button>
              </th>
              <th>Settings</th>
              <th aria-sort="none">
                <button
                  class="sort-button"
                  type="button"
                  data-sort-key="deviceTypes"
                  data-sort-type="string"
                  data-sort-default="asc"
                >
                  Device Types
                  <span class="sort-arrows" aria-hidden="true">
                    <span class="sort-arrow-up"></span>
                    <span class="sort-arrow-down"></span>
                  </span>
                </button>
              </th>
              <th>Sensor Modalities</th>
            </tr>
          </thead>
          <tbody data-dataset-table-body>
            {datasets.map((dataset, index) => (
              <tr
                data-dataset-row
                data-dataset-name={dataset.name}
                data-dataset-paper-title={dataset.paperLink?.title ?? dataset.name}
                data-dataset-paper-url={dataset.paperLink?.url ?? ""}
                data-dataset-authors={JSON.stringify(dataset.paperDetail.authors ?? [])}
                data-dataset-year={dataset.detail.year}
                data-dataset-subjects={dataset.detail.subjects.toLocaleString("en-US")}
                data-dataset-activities={dataset.detail.activities.toLocaleString("en-US")}
                data-dataset-channels={dataset.detail.channels.toLocaleString("en-US")}
                data-dataset-settings={dataset.settingsLabel}
                data-dataset-device-types={dataset.deviceTypesLabel}
                data-dataset-sensor-modalities={dataset.sensorModalitiesLabel}
                data-dataset-settings-pills={labelData(dataset.settingParts)}
                data-dataset-device-type-pills={labelData(dataset.deviceTypeParts)}
                data-dataset-sensor-modality-pills={labelData(dataset.sensorModalityParts)}
                data-subjects-value={dataset.detail.subjects}
                data-activities-value={dataset.detail.activities}
                data-channels-value={dataset.detail.channels}
                data-setting-parts={splitList(dataset.detail.settings).join("|")}
                data-device-type-parts={splitList(dataset.detail.deviceTypes).join("|")}
                data-sensor-modality-parts={splitList(dataset.detail.sensorModalities).join("|")}
                data-sort-index={index}
                data-sort-year={dataset.detail.year}
                data-sort-subjects={dataset.detail.subjects}
                data-sort-activities={dataset.detail.activities}
                data-sort-channels={dataset.detail.channels}
                data-sort-device-types={dataset.deviceTypesLabel}
                tabindex="0"
                aria-label={`Open dataset details: ${dataset.name}`}
              >
                <td class="name-cell">
                  <strong>{dataset.name}</strong>
                  <span>{dataset.institutionSummary}</span>
                </td>
                <td>
                  <strong class="metric">{dataset.detail.year}</strong>
                </td>
                <td>
                  <strong class="metric">{dataset.detail.subjects}</strong>
                </td>
                <td>
                  <strong class="metric">{dataset.detail.activities}</strong>
                </td>
                <td>
                  <strong class="metric">{dataset.detail.channels}</strong>
                </td>
                <td>
                  <div class="pill-list" aria-label={`Settings: ${dataset.settingsLabel}`}>
                    {dataset.settingParts.map((part) => (
                      <span class="pill">{part.name}</span>
                    ))}
                  </div>
                </td>
                <td>
                  <div class="pill-list" aria-label={`Device Types: ${dataset.deviceTypesLabel}`}>
                    {dataset.deviceTypeParts.map((part) => (
                      <span class="pill">{part.name}</span>
                    ))}
                  </div>
                </td>
                <td>
                  <div
                    class="pill-list"
                    aria-label={`Sensor Modalities: ${dataset.sensorModalitiesLabel}`}
                  >
                    {dataset.sensorModalityParts.map((part) => (
                      <span class="pill">{part.name}</span>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="note-panel">
      <strong>{datasetDetails.source.table} abbreviations</strong>
      <p>{datasetDetails.source.abbreviations}</p>
    </section>

    <div class="modal-layer" data-dataset-modal hidden role="presentation">
      <button
        class="modal-backdrop"
        type="button"
        aria-label="Close dataset details"
        data-dataset-modal-close
      ></button>
      <section
        class="dataset-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="dataset-detail-title"
        tabindex="-1"
      >
        <div class="dataset-modal-header">
          <div>
            <h2 id="dataset-detail-title" data-dataset-modal-title></h2>
            <p data-dataset-modal-subtitle></p>
          </div>
          <button
            class="modal-close"
            type="button"
            aria-label="Close dataset details"
            data-dataset-modal-close
          ></button>
        </div>

        <div class="detail-metrics dataset-detail-metrics" aria-label="Dataset statistics">
          <div>
            <span>Year</span>
            <strong data-dataset-modal-field="year"></strong>
          </div>
          <div>
            <span>Subjects</span>
            <strong data-dataset-modal-field="subjects"></strong>
          </div>
          <div>
            <span>Activities</span>
            <strong data-dataset-modal-field="activities"></strong>
          </div>
          <div>
            <span>Channels</span>
            <strong data-dataset-modal-field="channels"></strong>
          </div>
          <div>
            <span>Settings</span>
            <div class="detail-pill-list" data-dataset-modal-pill-field="settings"></div>
          </div>
          <div>
            <span>Device Types</span>
            <div class="detail-pill-list" data-dataset-modal-pill-field="deviceTypes"></div>
          </div>
          <div>
            <span>Sensor Modalities</span>
            <div class="detail-pill-list" data-dataset-modal-pill-field="sensorModalities"></div>
          </div>
        </div>

        <div class="detail-info-card">
          <strong>{datasetDetails.source.table} stats</strong>
          <p>
            {datasetDetails.source.note} Abbreviations follow the paper:
            {datasetDetails.source.abbreviations}
          </p>
        </div>

        <div class="detail-section">
          <h3>Paper</h3>
          <a
            class="paper-link detail-paper-link"
            href=""
            target="_blank"
            rel="noreferrer"
            data-dataset-modal-paper
          >
            Open dataset paper PDF
          </a>
          <p class="muted" data-dataset-modal-paper-pending hidden>Paper link pending</p>
        </div>

        <div class="detail-section">
          <h3>Authors And Affiliations</h3>
          <ul class="author-list" data-dataset-modal-authors></ul>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  const datasetModal = document.querySelector("[data-dataset-modal]");
  const datasetDialog = datasetModal?.querySelector(".dataset-modal");
  const datasetModalTitle = datasetModal?.querySelector("[data-dataset-modal-title]");
  const datasetModalSubtitle = datasetModal?.querySelector("[data-dataset-modal-subtitle]");
  const datasetModalPaper = datasetModal?.querySelector("[data-dataset-modal-paper]");
  const datasetModalPaperPending = datasetModal?.querySelector(
    "[data-dataset-modal-paper-pending]",
  );
  const datasetModalAuthors = datasetModal?.querySelector("[data-dataset-modal-authors]");
  const datasetTableBody = document.querySelector("[data-dataset-table-body]");
  const datasetSortButtons = Array.from(document.querySelectorAll("[data-sort-key]"));
  const datasetRows = Array.from(document.querySelectorAll("[data-dataset-row]"));
  const visibleDatasetCount = document.querySelector("[data-visible-dataset-count]");
  let lastDatasetTrigger = null;
  const datasetSortState = {
    key: "year",
    direction: "desc",
    type: "number",
  };

  const modalFields = {
    year: datasetModal?.querySelector('[data-dataset-modal-field="year"]'),
    subjects: datasetModal?.querySelector('[data-dataset-modal-field="subjects"]'),
    activities: datasetModal?.querySelector('[data-dataset-modal-field="activities"]'),
    channels: datasetModal?.querySelector('[data-dataset-modal-field="channels"]'),
  };
  const modalPillFields = {
    settings: datasetModal?.querySelector('[data-dataset-modal-pill-field="settings"]'),
    deviceTypes: datasetModal?.querySelector('[data-dataset-modal-pill-field="deviceTypes"]'),
    sensorModalities: datasetModal?.querySelector(
      '[data-dataset-modal-pill-field="sensorModalities"]',
    ),
  };
  const groups = {
    settings: {
      allLabel: "All settings",
      noneLabel: "No settings",
      plural: "settings",
      inputs: Array.from(document.querySelectorAll('[data-filter-kind="settings"]')),
      summary: document.querySelector('[data-filter-summary="settings"]'),
      count: document.querySelector('[data-filter-count="settings"]'),
    },
    deviceTypes: {
      allLabel: "All device types",
      noneLabel: "No device types",
      plural: "device types",
      inputs: Array.from(document.querySelectorAll('[data-filter-kind="deviceTypes"]')),
      summary: document.querySelector('[data-filter-summary="deviceTypes"]'),
      count: document.querySelector('[data-filter-count="deviceTypes"]'),
    },
    sensorModalities: {
      allLabel: "All sensor modalities",
      noneLabel: "No sensor modalities",
      plural: "sensor modalities",
      inputs: Array.from(document.querySelectorAll('[data-filter-kind="sensorModalities"]')),
      summary: document.querySelector('[data-filter-summary="sensorModalities"]'),
      count: document.querySelector('[data-filter-count="sensorModalities"]'),
    },
  };
  const ranges = {
    subjects: {
      min: document.querySelector('[data-range-kind="subjects"][data-range-bound="min"]'),
      max: document.querySelector('[data-range-kind="subjects"][data-range-bound="max"]'),
      summary: document.querySelector('[data-range-summary="subjects"]'),
      count: document.querySelector('[data-range-count="subjects"]'),
    },
    activities: {
      min: document.querySelector('[data-range-kind="activities"][data-range-bound="min"]'),
      max: document.querySelector('[data-range-kind="activities"][data-range-bound="max"]'),
      summary: document.querySelector('[data-range-summary="activities"]'),
      count: document.querySelector('[data-range-count="activities"]'),
    },
    channels: {
      min: document.querySelector('[data-range-kind="channels"][data-range-bound="min"]'),
      max: document.querySelector('[data-range-kind="channels"][data-range-bound="max"]'),
      summary: document.querySelector('[data-range-summary="channels"]'),
      count: document.querySelector('[data-range-count="channels"]'),
    },
  };

  function setModalText(element, value) {
    if (element) element.textContent = value || "-";
  }

  function renderModalPills(element, value) {
    if (!element) return;

    const labels = (value || "").split("|").filter(Boolean);
    if (labels.length === 0) {
      element.textContent = "-";
      return;
    }

    element.replaceChildren(
      ...labels.map((label) => {
        const pill = document.createElement("span");
        pill.className = "pill";
        pill.textContent = label;
        return pill;
      }),
    );
  }

  function isInteractiveTarget(target) {
    return target instanceof Element && Boolean(target.closest("a, button"));
  }

  function datasetAuthors(row) {
    try {
      const authors = JSON.parse(row.dataset.datasetAuthors || "[]");
      return Array.isArray(authors) ? authors : [];
    } catch {
      return [];
    }
  }

  function renderDatasetAuthors(authors) {
    if (!datasetModalAuthors) return;

    datasetModalAuthors.replaceChildren();
    if (authors.length === 0) {
      const item = document.createElement("li");
      const pending = document.createElement("span");
      pending.textContent = "Author information pending";
      item.append(pending);
      datasetModalAuthors.append(item);
      return;
    }

    authors.forEach((author) => {
      const item = document.createElement("li");
      const name = document.createElement("strong");
      const affiliation = document.createElement("span");
      name.textContent = author.name || "Author pending";
      affiliation.textContent = author.affiliation || "Affiliation pending";
      item.append(name, affiliation);
      datasetModalAuthors.append(item);
    });
  }

  function openDatasetModal(row) {
    if (!datasetModal || !datasetDialog) return;

    lastDatasetTrigger = row;
    setModalText(datasetModalTitle, row.dataset.datasetName);
    setModalText(datasetModalSubtitle, row.dataset.datasetPaperTitle);
    setModalText(modalFields.year, row.dataset.datasetYear);
    setModalText(modalFields.subjects, row.dataset.datasetSubjects);
    setModalText(modalFields.activities, row.dataset.datasetActivities);
    setModalText(modalFields.channels, row.dataset.datasetChannels);
    renderModalPills(modalPillFields.settings, row.dataset.datasetSettingsPills);
    renderModalPills(modalPillFields.deviceTypes, row.dataset.datasetDeviceTypePills);
    renderModalPills(modalPillFields.sensorModalities, row.dataset.datasetSensorModalityPills);
    renderDatasetAuthors(datasetAuthors(row));

    const paperUrl = row.dataset.datasetPaperUrl || "";
    if (datasetModalPaper && datasetModalPaperPending) {
      datasetModalPaper.hidden = !paperUrl;
      datasetModalPaperPending.hidden = Boolean(paperUrl);
      datasetModalPaper.setAttribute("href", paperUrl);
      datasetModalPaper.setAttribute(
        "title",
        `Open paper: ${row.dataset.datasetPaperTitle || row.dataset.datasetName || "Dataset"}`,
      );
    }

    datasetModal.hidden = false;
    datasetDialog.focus();
  }

  function closeDatasetModal() {
    if (!datasetModal) return;

    datasetModal.hidden = true;
    if (lastDatasetTrigger) lastDatasetTrigger.focus();
    lastDatasetTrigger = null;
  }

  function selectedValues(kind) {
    return new Set(groups[kind].inputs.filter((input) => input.checked).map((input) => input.value));
  }

  function optionLabel(input) {
    return input
      .closest(".filter-option")
      ?.querySelector(".filter-name-toggle")
      ?.textContent.trim();
  }

  function updateSummary(kind) {
    const group = groups[kind];
    const checked = group.inputs.filter((input) => input.checked);
    const selectedCount = checked.length;
    const total = group.inputs.length;

    if (group.count) group.count.textContent = `${selectedCount}/${total}`;
    if (!group.summary) return;
    if (selectedCount === total) {
      group.summary.textContent = group.allLabel;
    } else if (selectedCount === 0) {
      group.summary.textContent = group.noneLabel;
    } else if (selectedCount === 1) {
      group.summary.textContent = optionLabel(checked[0]) ?? `1 ${kind}`;
    } else {
      group.summary.textContent = `${selectedCount} ${group.plural}`;
    }
  }

  function inputNumber(input, fallback) {
    const value = Number(input?.value);
    return Number.isFinite(value) ? value : fallback;
  }

  function rangeState(kind) {
    const range = ranges[kind];
    const defaultMin = inputNumber({ value: range.min?.dataset.rangeDefault }, 0);
    const defaultMax = inputNumber({ value: range.max?.dataset.rangeDefault }, 0);
    const rawMin = Math.max(0, inputNumber(range.min, defaultMin));
    const rawMax = Math.max(0, inputNumber(range.max, defaultMax));
    const min = Math.min(rawMin, rawMax);
    const max = Math.max(rawMin, rawMax);

    return {
      min,
      max,
      defaultMin,
      defaultMax,
      isDefault: min <= defaultMin && max >= defaultMax,
    };
  }

  function formatRangeValue(value) {
    return value.toLocaleString("en-US");
  }

  function updateRangeSummary(kind, state = rangeState(kind)) {
    const range = ranges[kind];
    if (range.summary) {
      range.summary.textContent = `${formatRangeValue(state.min)} - ${formatRangeValue(state.max)}`;
    }
    if (range.count) {
      range.count.textContent = state.isDefault ? "range" : "filtered";
    }
  }

  function isMetricInRange(rawValue, state) {
    if (rawValue === undefined || rawValue === null || rawValue === "") {
      return state.isDefault;
    }

    const value = Number(rawValue);
    if (!Number.isFinite(value)) return state.isDefault;
    return value >= state.min && value <= state.max;
  }

  function sortRawValue(row, key) {
    const attributeKey = key.replace(/[A-Z]/g, (letter) => `-${letter.toLowerCase()}`);
    return row.getAttribute(`data-sort-${attributeKey}`) ?? "";
  }

  function sortNumberValue(row, key) {
    const rawValue = sortRawValue(row, key).trim();
    if (!rawValue) return null;

    const value = Number(rawValue);
    return Number.isFinite(value) ? value : null;
  }

  function compareOriginalIndex(a, b) {
    return Number(a.dataset.sortIndex ?? 0) - Number(b.dataset.sortIndex ?? 0);
  }

  function compareSortValues(a, b, state) {
    const direction = state.direction === "asc" ? 1 : -1;

    if (state.type === "number") {
      const aValue = sortNumberValue(a, state.key);
      const bValue = sortNumberValue(b, state.key);

      if (aValue === null && bValue === null) return compareOriginalIndex(a, b);
      if (aValue === null) return 1;
      if (bValue === null) return -1;
      if (aValue !== bValue) return (aValue - bValue) * direction;
      return compareOriginalIndex(a, b);
    }

    const aValue = sortRawValue(a, state.key).toLowerCase();
    const bValue = sortRawValue(b, state.key).toLowerCase();

    if (!aValue && !bValue) return compareOriginalIndex(a, b);
    if (!aValue) return 1;
    if (!bValue) return -1;
    return aValue.localeCompare(bValue) * direction || compareOriginalIndex(a, b);
  }

  function updateDatasetSortButtons() {
    datasetSortButtons.forEach((button) => {
      const isActive = button.dataset.sortKey === datasetSortState.key;
      button.classList.toggle("is-active", isActive);
      button.dataset.sortDirection = isActive ? datasetSortState.direction : "";
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
      button
        .closest("th")
        ?.setAttribute(
          "aria-sort",
          isActive ? (datasetSortState.direction === "asc" ? "ascending" : "descending") : "none",
        );
    });
  }

  function applyDatasetSort() {
    if (!datasetTableBody) return;

    [...datasetRows]
      .sort((a, b) => compareSortValues(a, b, datasetSortState))
      .forEach((row) => datasetTableBody.append(row));
    updateDatasetSortButtons();
  }

  function rowParts(row, attributeName) {
    return (row.getAttribute(attributeName) ?? "").split("|").filter(Boolean);
  }

  function hasAnySelectedPart(row, attributeName, selectedParts) {
    const parts = rowParts(row, attributeName);
    return parts.length === 0 || parts.some((part) => selectedParts.has(part));
  }

  function updateDatasetFilters() {
    const selectedSettings = selectedValues("settings");
    const selectedSensorModalities = selectedValues("sensorModalities");
    const selectedDeviceTypes = selectedValues("deviceTypes");
    const subjectsRange = rangeState("subjects");
    const activitiesRange = rangeState("activities");
    const channelsRange = rangeState("channels");
    let visibleCount = 0;

    datasetRows.forEach((row) => {
      const isSettingVisible = hasAnySelectedPart(row, "data-setting-parts", selectedSettings);
      const isSensorVisible = hasAnySelectedPart(
        row,
        "data-sensor-modality-parts",
        selectedSensorModalities,
      );
      const isDeviceVisible = hasAnySelectedPart(row, "data-device-type-parts", selectedDeviceTypes);
      const isSubjectsVisible = isMetricInRange(row.dataset.subjectsValue, subjectsRange);
      const isActivitiesVisible = isMetricInRange(row.dataset.activitiesValue, activitiesRange);
      const isChannelsVisible = isMetricInRange(row.dataset.channelsValue, channelsRange);
      const isVisible =
        isSettingVisible &&
        isSensorVisible &&
        isDeviceVisible &&
        isSubjectsVisible &&
        isActivitiesVisible &&
        isChannelsVisible;

      row.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    });

    if (visibleDatasetCount) visibleDatasetCount.textContent = String(visibleCount);
    updateSummary("settings");
    updateSummary("deviceTypes");
    updateSummary("sensorModalities");
    updateRangeSummary("subjects", subjectsRange);
    updateRangeSummary("activities", activitiesRange);
    updateRangeSummary("channels", channelsRange);
  }

  document.querySelectorAll("[data-filter-action]").forEach((button) => {
    button.addEventListener("click", () => {
      const mode = button.getAttribute("data-filter-action");
      const kind = button.getAttribute("data-filter-target");
      const group = groups[kind];

      if (!group) return;
      group.inputs.forEach((input) => {
        input.checked = mode === "all";
      });
      updateDatasetFilters();
    });
  });

  document.querySelectorAll("[data-range-reset]").forEach((button) => {
    button.addEventListener("click", () => {
      const kind = button.getAttribute("data-range-reset");
      const range = ranges[kind];
      if (!range) return;

      range.min.value = range.min.dataset.rangeDefault;
      range.max.value = range.max.dataset.rangeDefault;
      updateDatasetFilters();
    });
  });

  document.querySelectorAll(".dataset-filter details").forEach((details) => {
    details.addEventListener("toggle", () => {
      if (!details.open) return;
      details.closest(".filter-panel")?.querySelectorAll(".dataset-filter details").forEach((other) => {
        if (other !== details) other.open = false;
      });
    });
  });

  Object.values(groups).forEach((group) => {
    group.inputs.forEach((input) => {
      input.addEventListener("change", updateDatasetFilters);
    });
  });

  Object.values(ranges).forEach((range) => {
    [range.min, range.max].forEach((input) => {
      input.addEventListener("input", updateDatasetFilters);
      input.addEventListener("change", updateDatasetFilters);
    });
  });

  datasetSortButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.dataset.sortKey;
      if (!key) return;

      if (datasetSortState.key === key) {
        datasetSortState.direction = datasetSortState.direction === "asc" ? "desc" : "asc";
      } else {
        datasetSortState.key = key;
        datasetSortState.type = button.dataset.sortType || "string";
        datasetSortState.direction = button.dataset.sortDefault || "asc";
      }

      applyDatasetSort();
    });
  });

  datasetRows.forEach((row) => {
    row.addEventListener("click", (event) => {
      if (isInteractiveTarget(event.target)) return;
      openDatasetModal(row);
    });

    row.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();
      openDatasetModal(row);
    });
  });

  document.querySelectorAll("[data-dataset-modal-close]").forEach((button) => {
    button.addEventListener("click", closeDatasetModal);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && datasetModal && !datasetModal.hidden) {
      closeDatasetModal();
    }
  });

  applyDatasetSort();
  updateDatasetFilters();
</script>

